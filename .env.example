# ---------------------------------------------------------------------------
# Required — obtain from your Todoist account settings and Anthropic console
# ---------------------------------------------------------------------------
TODOIST_API_TOKEN=your_todoist_api_token_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ---------------------------------------------------------------------------
# Optional — all have sensible defaults
# ---------------------------------------------------------------------------

# Anthropic model to use (default: claude-opus-4-5)
CLAUDE_MODEL=claude-opus-4-5

# Seconds between Todoist polls in continuous mode (default: 30)
POLL_INTERVAL=30

# Maximum number of tasks to process in parallel (default: 4)
MAX_WORKERS=4

# Todoist label that triggers processing (default: claude)
CLAUDE_LABEL=claude

# Status labels managed by this tool — change these if your Todoist workspace
# already uses different label names for these states.
LABEL_PENDING=pending
LABEL_BLOCKED=blocked
LABEL_READY_FOR_REVIEW=ready-for-review
