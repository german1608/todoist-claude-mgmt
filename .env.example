# Required
TODOIST_API_TOKEN=your-todoist-api-token-here

# Optional — Todoist structure
CLAUDE_PROJECT_NAME=Claude Tasks
CLAUDE_LABEL=claude
POLL_INTERVAL_MS=60000

# Optional — Todoist section names
SECTION_QUEUED=Queued
SECTION_IN_PROGRESS=In Progress
SECTION_BLOCKED=Blocked
SECTION_DONE=Done

# Optional — Todoist label names
LABEL_IN_PROGRESS=in-progress
LABEL_BLOCKED=blocked
LABEL_PR_MONITOR=pr-monitor
LABEL_CODING=coding

# Optional — Claude settings
MAX_CONCURRENT_SESSIONS=5
CLAUDE_PERMISSION_MODE=auto
DEFAULT_REPO_PATH=/home/gerobayopaz/repos
CLAUDE_MODEL=

# Optional — Logging
LOG_LEVEL=info
